<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.MediaVault" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_variant</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.MediaVault" parent="Base.Theme.MediaVault" />

    <!-- Card Style -->
    <style name="MediaVault.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Section Header -->
    <style name="MediaVault.SectionHeader" parent="">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/on_background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Rating Badge -->
    <style name="MediaVault.RatingBadge" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <!-- Genre Chip -->
    <style name="MediaVault.GenreChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

</resources>